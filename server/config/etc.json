{
  "port": 8430,
  "save_requests_dir": "output",
  "endpoints": [
    {
      "endpoint": "/dir",
      "method": "GET",
      "response": {
        "newNonce": "http://localhost:8430/newNonce",
        "newAccount": "http://localhost:8430/newAccount",
        "newOrder": "http://localhost:8430/newOrder",
        "newAuthz": "http://localhost:8430/newAuthz", 
        "revokeCert": "http://localhost:8430/revokeCert",
        "keyChange": "http://localhost:8430/keyChange"
      },
      "status": 200
    },
    {
      "endpoint": "/newNonce",
      "method": "GET",
      "response": null,
      "status": 200,
      "headers": {"Replay-Nonce": "U2l4dGVlbkJ5dGVOb25jZQ"}
    },
    {
      "endpoint": "/newAccount",
      "method": "POST",
      "response": {
        "status": "valid",
        "contact": [
          "mailto:cert-admin@example.org",
          "mailto:admin@example.org"
        ],
        "termsOfServiceAgreeed": true,
        "externalAccountBinding": "JWS(externalAccount)",
        "orders": "http://localhost:8430/orders"
      },
      "status": 201,
      "headers": {
        "Replay-Nonce": "U2l4dGVlbkJ5dGVOb25jZQ", 
        "Location": "http://localhost:8430/id"
      }
    },
    {
      "endpoint": "/id",
      "method": "POST",
      "response": {
        "status": "deactivated",
        "contact": [
          "mailto:cert-admin@example.org",
          "mailto:admin@example.org"
        ],
        "termsOfServiceAgreeed": true,
        "externalAccountBinding": "JWS(externalAccount)",
        "orders": "http://localhost:8430/orders"
      },
      "status": 200,
      "headers": {
        "Replay-Nonce": "U2l4dGVlbkJ5dGVOb25jZQ", 
        "Location": "http://localhost:8430/id"
      }
    }
  ]
}
